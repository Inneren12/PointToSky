<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- CAM-2c physical-camera provenance experiment (task §4). internalDebug-only via AGP's
         per-source-set manifest merge - never present in publicDebug/internalRelease/publicRelease.
         Not exported: launched only in-app, via the existing CAM diagnostics dialog's "Open
         physical-camera experiment" action (a same-app, same-process Intent - always permitted
         regardless of exported="false", which restricts only other apps/processes), never by another
         app, and never documented as reachable via `adb shell am start`. -->
    <application>
        <activity
            android:name="dev.pointtosky.mobile.ar.camera.PhysicalCameraBindingExperimentActivity"
            android:exported="false"
            android:label="CAM-2c physical camera binding"
            android:screenOrientation="portrait" />

        <!-- CAM-2c frame-content correspondence experiment: same internalDebug-only, non-exported,
             in-app-launch-only convention as the physical-camera-binding experiment above. -->
        <activity
            android:name="dev.pointtosky.mobile.ar.camera.FrameContentCorrespondenceExperimentActivity"
            android:exported="false"
            android:label="CAM-2c frame-content correspondence"
            android:screenOrientation="portrait" />

        <!-- CAM-2c frame-content correspondence experiment: real image/svg+xml *file* sharing for the
             printable target (FrameContentTargetSvgSharing.kt). The existing "${applicationId}.logs"
             FileProvider (main manifest) only covers a files-path "crash/" subdirectory - it does not
             cover any cache-path, so it cannot be reused for this cache-backed file. A dedicated
             internalDebug-only provider is added instead, scoped by filepaths_cam2c_target.xml's
             cache-path to only its own "cam2c_target/" cache subdirectory - never exported, never usable
             by another app, grantUriPermissions=true so a temporary read grant can be extended to
             whichever app the chooser launches. Uses a distinct FileProvider subclass
             (FrameContentTargetSvgFileProvider), not androidx.core.content.FileProvider directly - AGP's
             manifest merger keys <provider> by android:name alone, so a second bare
             "androidx.core.content.FileProvider" entry collides with the existing ".logs" one even
             though their authorities/resource differ. -->
        <provider
            android:name="dev.pointtosky.mobile.ar.camera.FrameContentTargetSvgFileProvider"
            android:authorities="${applicationId}.cam2c.target"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths_cam2c_target" />
        </provider>
    </application>
</manifest>
